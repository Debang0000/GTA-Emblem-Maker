<Window x:Class="GTAEmblemMaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GTA Emblem Maker"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        Background="#F3F4F2"
        Foreground="#20221F"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Closing="Window_Closing">
  <Window.Resources>
    <SolidColorBrush x:Key="AccentBrush" Color="#2E6B46" />
    <SolidColorBrush x:Key="BorderBrush" Color="#C8CCC5" />
    <DrawingBrush x:Key="CheckerBrush" TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
      <DrawingBrush.Drawing>
        <DrawingGroup>
          <GeometryDrawing Brush="#F8F8F7" Geometry="M0,0 H20 V20 H0 Z" />
          <GeometryDrawing Brush="#E5E7E3" Geometry="M0,0 H10 V10 H0 Z M10,10 H20 V20 H10 Z" />
        </DrawingGroup>
      </DrawingBrush.Drawing>
    </DrawingBrush>
    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="14,6" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="BorderBrush" Value="#AEB3AB" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#20221F" />
    </Style>
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style TargetType="TextBlock">
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="18,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="20" />
          <ColumnDefinition Width="260" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Button x:Name="OpenButton" Grid.Column="0" Content="Open Image" Click="OpenButton_Click" />
        <StackPanel Grid.Column="2">
          <TextBlock Text="Pipeline" FontSize="11" Foreground="#656A63" Margin="0,0,0,4" />
          <ComboBox x:Name="ProfileBox" MinHeight="34" DisplayMemberPath="DisplayName" SelectionChanged="ProfileBox_SelectionChanged" />
          <CheckBox x:Name="GenerateAllBox" Content="Generate all" Margin="0,7,0,0" Checked="GenerateAllBox_Changed" Unchecked="GenerateAllBox_Changed" />
        </StackPanel>
        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
          <Button x:Name="StartButton" Style="{StaticResource PrimaryButton}" Content="Start" Click="StartButton_Click" IsEnabled="False" />
          <Button x:Name="StopButton" Content="Stop" Click="StopButton_Click" IsEnabled="False" />
          <Button x:Name="CopyButton" Content="Copy Import Code" Click="CopyButton_Click" IsEnabled="False" />
          <Button x:Name="FolderButton" Content="Open Run Folder" Click="FolderButton_Click" IsEnabled="False" Margin="0" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="18">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="18" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <TextBlock Grid.Column="0" Text="Source" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,8" />
      <Grid Grid.Column="2" Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="Output" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
        <ComboBox x:Name="ResultsBox" Grid.Column="1" MinHeight="30" DisplayMemberPath="DisplayName" SelectionChanged="ResultsBox_SelectionChanged" IsEnabled="False" />
      </Grid>

      <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource CheckerBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
        <Grid>
          <Image x:Name="SourcePreview" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
          <TextBlock x:Name="SourceEmptyText" Text="No source selected" Foreground="#73786F" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
      </Border>
      <Border Grid.Row="1" Grid.Column="2" Background="{StaticResource CheckerBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
        <Grid>
          <Image x:Name="OutputPreview" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" />
          <TextBlock x:Name="OutputEmptyText" Text="No output" Foreground="#73786F" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Grid>
      </Border>

      <TextBlock x:Name="SourceInfoText" Grid.Row="2" Grid.Column="0" Foreground="#565B54" Margin="0,8,0,0" />
      <TextBlock x:Name="OutputInfoText" Grid.Row="2" Grid.Column="2" Foreground="#565B54" Margin="0,8,0,0" />
    </Grid>

    <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="18,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ProgressBar x:Name="RunProgress" Grid.Row="0" Grid.Column="0" Height="8" Minimum="0" Maximum="1500" Value="0" Foreground="{StaticResource AccentBrush}" Background="#E1E4DF" BorderThickness="0" Margin="0,0,18,8" />
        <TextBlock x:Name="ProgressText" Grid.Row="0" Grid.Column="1" Text="0 / 1500" Foreground="#565B54" />
        <TextBlock x:Name="StatusText" Grid.Row="1" Grid.ColumnSpan="2" Text="Ready" Foreground="#424740" />
      </Grid>
    </Border>
  </Grid>
</Window>
