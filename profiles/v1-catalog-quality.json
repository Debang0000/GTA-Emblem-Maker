{
  "schemaVersion": 1,
  "id": "v1-catalog-quality",
  "displayName": "Official Catalog Quality",
  "isDefault": false,
  "minimumEngineVersion": "1.1.2",
  "pipeline": {
    "runner": "catalog-compatible"
  },
  "stages": [
    {
      "id": "current-image-fit",
      "maxLayers": 1500,
      "budget": 1250000,
      "minAxis": 2,
      "residentSelectLayer": true,
      "residentSelection": "code-aware-proxy",
      "residentDeviceChunk": true,
      "residentDeviceChunkRounds": 16,
      "shapeChoicesByLayer": [
        { "fromLayer": 1, "shapes": ["rotated"] },
        { "fromLayer": 501, "shapes": ["rotated", "rotated-triangle", "rotated-rect", "line-rect"] }
      ],
      "catalogSearch": {
        "fromLayer": 501,
        "candidatesPerGroup": 512,
        "identities": [
          "catalog-curve-01",
          "catalog-curve-07",
          "catalog-curve-61",
          "catalog-curve-62",
          "catalog-curve-66",
          "catalog-curve-67",
          "catalog-curve-71",
          "catalog-curve-72",
          "catalog-curve-73",
          "catalog-round-08",
          "catalog-round-18"
        ]
      },
      "opaqueWeightMapSchedule": [
        { "fromLayer": 1, "weightMapId": "uniform" },
        { "fromLayer": 251, "weightMapId": "edge-plus-laplacian" }
      ],
      "transparentWeightMapSchedule": [
        { "fromLayer": 1, "weightMapId": "alpha-protect" },
        { "fromLayer": 251, "weightMapId": "edge-plus-laplacian-alpha-protect" }
      ],
      "layerOptimization": {
        "overfitPercent": 0,
        "refinePercent": 0,
        "rankingPoolMultiplier": 2,
        "replacementPercent": 0,
        "replacementTileSize": 64,
        "maxTileRegressionPercent": 0.5
      },
      "perceptualRerank": {
        "backend": "native-edge-detail",
        "model": "native-edge-detail-v1",
        "batchSize": 48,
        "shapeBalanced": true,
        "topK": 48,
        "eachTopK": 12,
        "firstRerankLayer": 1001,
        "tileSize": 256,
        "tileStride": 128,
        "maxTilesPerCandidate": 4,
        "perceptualRankWeight": 0.5,
        "middleEvery": 1,
        "finalEvery": 1,
        "batchFiles": true
      }
    }
  ]
}
