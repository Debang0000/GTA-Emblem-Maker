{
  "schemaVersion": 1,
  "id": "v1-beam-clean",
  "displayName": "Beam Clean",
  "isDefault": false,
  "minimumEngineVersion": "1.0.0",
  "pipeline": {
    "runner": "beam",
    "beamWidth": 2,
    "branchFactor": 2
  },
  "stages": [
    {
      "id": "current-image-fit",
      "maxLayers": 1600,
      "budget": 1270000,
      "minAxis": 2,
      "residentSelectLayer": true,
      "residentSelection": "code-aware-proxy",
      "residentDeviceChunk": true,
      "residentDeviceChunkRounds": 16,
      "shapeChoicesByLayer": [
        { "fromLayer": 1, "shapes": ["rotated"] }
      ],
      "opaqueWeightMapSchedule": [
        { "fromLayer": 1, "weightMapId": "uniform" }
      ],
      "transparentWeightMapSchedule": [
        { "fromLayer": 1, "weightMapId": "alpha-protect" }
      ],
      "layerOptimization": {
        "overfitPercent": 0,
        "refinePercent": 0,
        "rankingPoolMultiplier": 2,
        "replacementPercent": 0,
        "replacementTileSize": 64,
        "maxTileRegressionPercent": 0.5
      },
      "perceptualRerank": {
        "backend": "lpips-directml",
        "model": "lpips-alex-v0.1-224",
        "batchSize": 48,
        "shapeBalanced": true,
        "topK": 48,
        "eachTopK": 12,
        "firstRerankLayer": 801,
        "tileSize": 256,
        "tileStride": 128,
        "maxTilesPerCandidate": 4,
        "perceptualRankWeight": 0.5,
        "middleEvery": 1,
        "finalEvery": 1,
        "batchFiles": true
      }
    }
  ]
}
