{
  "schemaVersion": 1,
  "id": "v1-clean-logo",
  "displayName": "Clean Logo",
  "isDefault": false,
  "minimumEngineVersion": "1.1.3",
  "pipeline": {
    "runner": "clean-logo"
  },
  "stages": [
    {
      "id": "current-image-fit",
      "maxLayers": 1500,
      "budget": 1250000,
      "minAxis": 4,
      "residentSelectLayer": true,
      "residentSelection": "code-aware-proxy",
      "residentDeviceChunk": true,
      "residentDeviceChunkRounds": 16,
      "shapeChoicesByLayer": [
        {
          "fromLayer": 1,
          "shapes": [
            "rotated",
            "rotated-triangle",
            "rotated-rect"
          ]
        }
      ],
      "opaqueWeightMapSchedule": [
        {
          "fromLayer": 1,
          "weightMapId": "edge-plus-laplacian"
        }
      ],
      "transparentWeightMapSchedule": [
        {
          "fromLayer": 1,
          "weightMapId": "edge-plus-laplacian-alpha-protect"
        }
      ],
      "layerOptimization": {
        "overfitPercent": 0,
        "refinePercent": 0,
        "rankingPoolMultiplier": 2,
        "replacementPercent": 0,
        "replacementTileSize": 16,
        "maxTileRegressionPercent": 0
      }
    }
  ]
}
